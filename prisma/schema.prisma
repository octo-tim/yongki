// 화장품 용기 제작관리 — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 프로젝트 상태 (자동 계산 + 수동 보류)
enum ProjectStatus {
  IN_PROGRESS   // 진행중
  ON_HOLD       // 제작보류
  READY_TO_SHIP // 출고대기
  DONE          // 완료
  DELAYED       // 지연
  AWAITING_DELIVERY // 인도대기
}

enum StepType {
  PRODUCTION // 제작 타임라인
  SHIPPING   // 출고 타임라인
}

enum PaymentType {
  DEPOSIT // 계약금
  BALANCE // 잔금
}

// 상태 표시 설정 (라벨/색상/순서) — enum 값별 1행
model StatusSetting {
  id        String        @id @default(cuid())
  key       ProjectStatus @unique
  label     String
  color     String        // 팔레트 키 (blue, amber, emerald ...)
  sortOrder Int           @default(0)

  @@map("status_settings")
}

// 단계(제작/출고 하위업무) 템플릿 — 신규 프로젝트 생성 시 사용
model StepTemplate {
  id        String   @id @default(cuid())
  type      StepType
  group     String   @default("")
  name      String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("step_templates")
}

enum UserRole {
  ADMIN
  STAFF
}

// 1. 사용자
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managedProjects Project[] @relation("ProjectManager")
  memos           ProjectMemo[]
  notes           ProjectNote[]
  workLogs        WorkLog[]    @relation("WorkLogAssignee")
  createdWorkLogs WorkLog[]    @relation("WorkLogCreator")
  logs            ProjectLog[]

  @@map("users")
}

// 2. 업체 (발주 고객사)
model Client {
  id        String   @id @default(cuid())
  name      String
  contact   String?  // 담당자
  phone     String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]

  @@map("clients")
}

// 3. 공장 (중국/해외 생산처)
model Factory {
  id          String   @id @default(cuid())
  name        String   // 공장명 / 微信群名
  region      String?  // 지역 (广州, 余姚 등)
  category    String?  // 품목 (튜브용기, 향수병 등)
  contactType String?  // 소통수단 (카카오톡, 위쳇 등)
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]

  @@map("factories")
}

// 4. 프로젝트 (제작 건)
model Project {
  id          String   @id @default(cuid())
  orderDate   DateTime?            // 주문일자
  orderNo     String?              // 주문번호
  productName String                // 상품명
  productPhoto String?             // 제품사진 (업로드 경로)
  quantity    Int?                 // 수량
  deposit     Decimal?  @db.Decimal(14, 2) // 계약금
  balance     Decimal?  @db.Decimal(14, 2) // 잔금
  note        String?              // 특이사항

  status       ProjectStatus  @default(IN_PROGRESS)
  manualStatus ProjectStatus? // 사용자가 수동 지정한 상태 (있으면 자동계산보다 우선)
  manualHold   Boolean        @default(false) // 사용자가 제작보류로 설정

  // 제작 일정
  factoryOrderDate       DateTime? // 공장 주문일자
  expectedCompletionDate DateTime? // 완성 예정일
  productionCompleteDate DateTime? // 생산 완료일

  // 출고 일정
  warehouseInDate     DateTime? // 창고 입고일
  inspectionDate      DateTime? // 검품일
  shipOutDate         DateTime? // 출고일
  koreaArrivalDate    DateTime? // 한국 도착일
  customerDeliveryDate DateTime? // 고객 인도일

  // 관계
  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id])
  factoryId String?
  factory   Factory? @relation(fields: [factoryId], references: [id])
  managerId String?
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id])

  steps ProjectStep[]
  files ProjectFile[]
  memos ProjectMemo[]
  notes ProjectNote[]
  workLogs WorkLog[]
  payments Payment[]
  logs  ProjectLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([factoryId])
  @@map("projects")
}

// 5. 프로젝트 단계 (타임라인)
model ProjectStep {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      StepType  // 제작일정관리(PRODUCTION) / 출고관리(SHIPPING)
  group     String    @default("") // 2단계: 공장주문일자/완성예정일/제작확인/창고입고...
  name      String    // 3단계(leaf): 파일수령/생산완료/검품 ...
  order     Int       // 정렬 순서
  done      Boolean   @default(false)
  doneAt    DateTime? // 완료 일자
  staff     String?   // 담당 직원 (자유 입력)
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
  @@map("project_steps")
}

// 6. 프로젝트 파일
model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName   String   // 원본 파일명
  filePath   String   // 저장 경로
  fileType   String?  // mime
  fileSize   Int?     // bytes
  createdAt  DateTime @default(now())

  @@index([projectId])
  @@map("project_files")
}

// 7. 프로젝트 메모
model ProjectMemo {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("project_memos")
}

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([projectId])
  @@map("project_notes")
}

enum WorkStatus {
  TODO  // 예정
  DOING // 진행중
  DONE  // 완료
  HOLD  // 보류
}

model WorkLog {
  id         String     @id @default(cuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?      @relation("WorkLogAssignee", fields: [assigneeId], references: [id])
  creatorId  String?
  creator    User?      @relation("WorkLogCreator", fields: [creatorId], references: [id])
  content    String     // 진행내역
  status     WorkStatus @default(DOING)
  startDate  DateTime?  // 시작일
  endDate    DateTime?  // 종료일
  createdAt  DateTime   @default(now())

  @@index([projectId])
  @@index([assigneeId])
  @@map("work_logs")
}

model Payment {
  id         String      @id @default(cuid())
  projectId  String
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type       PaymentType // 계약금 / 잔금
  amount     Decimal     @db.Decimal(14, 2)
  receivedAt DateTime    // 수령일
  memo       String?
  createdAt  DateTime    @default(now())

  @@index([projectId])
  @@index([receivedAt])
  @@map("payments")
}

// 8. 프로젝트 로그 (이력)
model ProjectLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String   // CREATE / UPDATE / STATUS_CHANGE / FILE_UPLOAD ...
  message   String
  createdAt DateTime @default(now())

  @@index([projectId])
  @@map("project_logs")
}

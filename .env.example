# ── PostgreSQL ──────────────────────────────────────────
# 로컬: 아래처럼 직접 지정
# Railway: PostgreSQL 플러그인 추가 후 ${{Postgres.DATABASE_URL}} 참조 변수로 연결
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/container_mgmt?schema=public"

# ── NextAuth ────────────────────────────────────────────
# 로컬: http://localhost:3000 / Railway: 배포 도메인(https://...up.railway.app)
NEXTAUTH_URL="http://localhost:3000"
# openssl rand -base64 32 결과값을 넣으세요
NEXTAUTH_SECRET="change-me-with-openssl-rand-base64-32"
